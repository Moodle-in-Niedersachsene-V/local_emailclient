<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/emailclient/db" VERSION="20260618" COMMENT="XMLDB data definitions for local_emailclient"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_emailclient_accounts" COMMENT="Per-user IMAP/SMTP account configuration for the e-mail client local plugin">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Owning Moodle user"/>
        <FIELD NAME="imaphost" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="imapport" TYPE="int" LENGTH="6" NOTNULL="true" DEFAULT="993" SEQUENCE="false"/>
        <FIELD NAME="imapsecurity" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="ssl" SEQUENCE="false" COMMENT="none|ssl|tls"/>
        <FIELD NAME="imapusername" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="imappassword" TYPE="text" NOTNULL="true" SEQUENCE="false" COMMENT="Encrypted with core\\encryption"/>
        <FIELD NAME="smtphost" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="smtpport" TYPE="int" LENGTH="6" NOTNULL="true" DEFAULT="587" SEQUENCE="false"/>
        <FIELD NAME="smtpsecurity" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="tls" SEQUENCE="false" COMMENT="none|ssl|tls"/>
        <FIELD NAME="smtpusername" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="smtppassword" TYPE="text" NOTNULL="true" SEQUENCE="false" COMMENT="Encrypted with core\\encryption"/>
        <FIELD NAME="fromname" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="fromemail" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="signature" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign-unique" FIELDS="userid" REFTABLE="user" REFFIELDS="id" COMMENT="One stored account per Moodle user"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
